{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://referenciel-manager/schemas/json-canonique-sequence.json",
  "title": "JSON canonique — Séquence",
  "description": "Valide la STRUCTURE d'un manifeste canonique de type 'sequence' (sequence → paliers → dossier technique / QCM / activité / checklist). Les invariants sémantiques (ordre unique et contigu, bonne_reponse ∈ choix, fichiers présents dans le bundle) sont validés par l'importeur. Champs additionnels tolérés.",
  "type": "object",
  "required": ["type", "identifiant", "version", "sources", "provenance", "niveau_classe", "titre", "organisation", "seances"],
  "properties": {
    "type": { "const": "sequence" },
    "identifiant": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "sources": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/source" } },
    "provenance": { "$ref": "#/$defs/provenance" },
    "niveau_classe": { "$ref": "#/$defs/codeIntitule" },
    "titre": { "type": "string" },
    "presentation": { "type": "string" },
    "organisation": {
      "type": "object",
      "required": ["activite_glissante", "ordre_impose"],
      "properties": {
        "activite_glissante": { "type": "boolean" },
        "ordre_impose": { "type": "boolean" }
      }
    },
    "seances": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/seance" } },
    "relations": {
      "type": "object",
      "properties": {
        "seance_competences": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["seance", "competences"],
            "properties": {
              "seance": { "type": "string" },
              "competences": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": ["source_id", "source_type", "source_fichier"],
      "properties": {
        "source_id": { "type": "string" },
        "source_type": { "type": "string", "enum": ["pdf_officiel", "scpro", "odt", "starter"] },
        "source_fichier": { "type": "string" },
        "source_note": { "type": "string" }
      }
    },
    "provenance": {
      "type": "object",
      "required": ["date_extraction", "methode", "point_entree"],
      "properties": {
        "date_extraction": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "methode": { "type": "string" },
        "point_entree": { "type": "string", "enum": ["referentiel_officiel", "cpro_scpro", "starter"] }
      }
    },
    "codeIntitule": {
      "type": "object",
      "required": ["code", "intitule"],
      "properties": {
        "code": { "type": "string" },
        "intitule": { "type": "string" }
      }
    },
    "ref": {
      "type": "object",
      "required": ["fichier"],
      "properties": {
        "fichier": { "type": "string" }
      }
    },
    "lettre": { "type": "string", "enum": ["A", "B", "C"] },
    "seance": {
      "type": "object",
      "required": ["id", "ordre", "titre", "dossier_technique"],
      "properties": {
        "id": { "type": "string" },
        "ordre": { "type": "integer", "minimum": 1 },
        "titre": { "type": "string" },
        "theme": { "type": "string" },
        "production_attendue": { "type": "string" },
        "dossier_technique": {
          "type": "object",
          "required": ["ressources"],
          "properties": {
            "titre": { "type": "string" },
            "ressources": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["type", "titre", "ordre"],
                "properties": {
                  "type": { "enum": ["markdown", "video", "audio", "lien"] },
                  "titre": { "type": "string" },
                  "ordre": { "type": "integer" },
                  "contenu": { "type": "string" },
                  "fichier": { "type": "string" },
                  "url": { "type": "string" }
                }
              }
            }
          }
        },
        "qcm": { "$ref": "#/$defs/qcm" },
        "activite": {
          "type": "object",
          "required": ["id"],
          "properties": {
            "id": { "type": "string" },
            "objectif": { "type": "string" },
            "fichier": { "type": "string" },
            "etapes": { "type": "array", "items": { "type": "string" } }
          }
        },
        "checklist": { "$ref": "#/$defs/checklist" },
        "images": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["fichier"],
            "properties": {
              "fichier": { "type": "string" },
              "legende": { "type": "string" }
            }
          }
        },
        "ressources": {
          "type": "object",
          "properties": {
            "eleve": { "type": "array", "items": { "type": "string" } },
            "professeur": { "type": "array", "items": { "type": "string" } }
          }
        },
        "source_ids": { "type": "array", "items": { "type": "string" } }
      }
    },
    "qcm": {
      "type": "object",
      "required": ["id", "validation", "questions"],
      "properties": {
        "id": { "type": "string" },
        "format_reponse": { "type": "string" },
        "validation": {
          "type": "object",
          "required": ["seuil"],
          "properties": { "seuil": { "type": "string" } }
        },
        "questions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["numero", "enonce", "choix", "bonne_reponse"],
            "properties": {
              "numero": { "type": "integer", "minimum": 1 },
              "enonce": { "type": "string" },
              "choix": {
                "type": "array",
                "minItems": 2,
                "items": {
                  "type": "object",
                  "required": ["lettre", "texte"],
                  "properties": {
                    "lettre": { "$ref": "#/$defs/lettre" },
                    "texte": { "type": "string" }
                  }
                }
              },
              "bonne_reponse": { "$ref": "#/$defs/lettre" }
            }
          }
        }
      }
    },
    "checklist": {
      "type": "object",
      "required": ["id", "sections"],
      "properties": {
        "id": { "type": "string" },
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["numero", "titre", "items"],
            "properties": {
              "numero": { "type": "integer", "minimum": 1 },
              "titre": { "type": "string" },
              "items": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["libelle"],
                  "properties": { "libelle": { "type": "string" } }
                }
              }
            }
          }
        },
        "decision_finale": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "etat": { "type": "string" },
              "decision": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
