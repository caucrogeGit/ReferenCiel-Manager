{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://referenciel-manager/schemas/json-canonique-referentiel-niveau-classe.json",
  "title": "JSON canonique — référentiel niveau-classe",
  "description": "Valide la STRUCTURE d'un JSON canonique de type 'referentiel_niveau_classe' (enveloppe commune + corps à deux couches CIEL/famille). Les invariants sémantiques (unicité des id, résolution des références de relations) sont validés par l'importeur, pas par ce schéma. Un document conforme peut être plus riche (champs additionnels tolérés).",
  "type": "object",
  "required": ["type", "identifiant", "version", "sources", "provenance", "formation", "niveau_classe"],
  "properties": {
    "type": { "const": "referentiel_niveau_classe" },
    "identifiant": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "sources": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/source" } },
    "provenance": { "$ref": "#/$defs/provenance" },
    "formation": { "$ref": "#/$defs/formationRef" },
    "niveau_classe": { "$ref": "#/$defs/codeIntitule" },
    "poles_activites": { "type": "array", "items": { "$ref": "#/$defs/pole" } },
    "activites_professionnelles": { "type": "array", "items": { "$ref": "#/$defs/activite" } },
    "competences": { "type": "array", "items": { "$ref": "#/$defs/competence" } },
    "indicateurs_reussite": { "type": "array", "items": { "$ref": "#/$defs/indicateur" } },
    "famille_competences": { "type": "array", "items": { "$ref": "#/$defs/familleCompetence" } },
    "relations": { "$ref": "#/$defs/relations" }
  },
  "$defs": {
    "sourceIds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "source": {
      "type": "object",
      "required": ["source_id", "source_type", "source_fichier"],
      "properties": {
        "source_id": { "type": "string" },
        "source_type": { "type": "string", "enum": ["pdf_officiel", "scpro", "odt", "starter"] },
        "source_fichier": { "type": "string" },
        "source_note": { "type": "string" }
      }
    },
    "provenance": {
      "type": "object",
      "required": ["date_extraction", "methode", "point_entree"],
      "properties": {
        "date_extraction": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "methode": { "type": "string" },
        "point_entree": { "type": "string", "enum": ["referentiel_officiel", "cpro_scpro"] }
      }
    },
    "codeIntitule": {
      "type": "object",
      "required": ["code", "intitule"],
      "properties": {
        "code": { "type": "string" },
        "intitule": { "type": "string" }
      }
    },
    "formationRef": {
      "type": "object",
      "required": ["code", "intitule"],
      "properties": {
        "code": { "type": "string" },
        "intitule": { "type": "string" },
        "type": {
          "type": "string",
          "description": "Type de formation (ADR-023) : FAMILLE_METIERS, SPECIALITE_BAC_PRO, CAP, BP, BMA, CERTIFICAT_SPECIALISATION, FCIL, BTS, AUTRE. Défaut AUTRE à l'import si absent."
        }
      }
    },
    "pole": {
      "type": "object",
      "required": ["id", "intitule", "source_ids"],
      "properties": {
        "id": { "type": "string" },
        "intitule": { "type": "string" },
        "source_ids": { "$ref": "#/$defs/sourceIds" }
      }
    },
    "activite": {
      "type": "object",
      "required": ["id", "code", "intitule", "pole_id", "source_ids"],
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string", "pattern": "^[ERD][0-9]+$" },
        "intitule": { "type": "string" },
        "pole_id": { "type": "string" },
        "taches": { "type": "array", "items": { "type": "string" } },
        "conditions_exercice": {
          "type": "object",
          "properties": {
            "moyens": { "type": "array", "items": { "type": "string" } },
            "autonomie": { "type": "string" }
          }
        },
        "resultats_attendus": { "type": "array", "items": { "$ref": "#/$defs/idLibelle" } },
        "source_ids": { "$ref": "#/$defs/sourceIds" }
      }
    },
    "competence": {
      "type": "object",
      "required": ["id", "code", "intitule", "source_ids"],
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string", "pattern": "^C[0-9]{2}$" },
        "intitule": { "type": "string" },
        "connaissances": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["libelle"],
            "properties": {
              "libelle": { "type": "string" },
              "niveau_taxonomique": { "type": "integer", "minimum": 1, "maximum": 4 }
            }
          }
        },
        "criteres_evaluation": { "type": "array", "items": { "$ref": "#/$defs/critereEvaluation" } },
        "source_ids": { "$ref": "#/$defs/sourceIds" }
      }
    },
    "indicateur": {
      "type": "object",
      "required": ["id", "libelle", "origine", "source_ids"],
      "properties": {
        "id": { "type": "string" },
        "libelle": { "type": "string" },
        "origine": { "type": "string", "enum": ["resultat_attendu", "critere", "reformulation"] },
        "ref": { "type": "string" },
        "source_ids": { "$ref": "#/$defs/sourceIds" }
      }
    },
    "familleCompetence": {
      "type": "object",
      "required": ["code", "intitule", "source_ids"],
      "properties": {
        "code": { "type": "string", "pattern": "^CC[0-9]$" },
        "intitule": { "type": "string" },
        "source_ids": { "$ref": "#/$defs/sourceIds" }
      }
    },
    "idLibelle": {
      "type": "object",
      "required": ["id", "libelle"],
      "properties": {
        "id": { "type": "string" },
        "libelle": { "type": "string" }
      }
    },
    "critereEvaluation": {
      "type": "object",
      "required": ["id", "libelle"],
      "properties": {
        "id": { "type": "string" },
        "libelle": { "type": "string" },
        "savoir_etre": {
          "type": "boolean",
          "description": "Critère de type savoir-être (comportemental), rendu en italique dans le tunnel. Défaut false si absent."
        }
      }
    },
    "relations": {
      "type": "object",
      "properties": {
        "activites_competences": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["activite", "competences"],
            "properties": {
              "activite": { "type": "string" },
              "competences": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "competences_criteres": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["competence", "criteres"],
            "properties": {
              "competence": { "type": "string" },
              "criteres": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "activites_resultats_attendus": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["activite", "resultats"],
            "properties": {
              "activite": { "type": "string" },
              "resultats": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "cc_competences": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["cc", "competences"],
            "properties": {
              "cc": { "type": "string" },
              "competences": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    }
  }
}
