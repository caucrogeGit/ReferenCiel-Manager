# Application
APP_NAME=ReferenCiel-Manager
APP_ROUTES_MODULE=mvc.routes

# Upload
# Le noyau ne garde que le plafond de corps multipart (ADR-032).
# UPLOAD_ROOT et UPLOAD_ALLOWED_* sont lues par l'opt-in forge-mvc-files.
UPLOAD_MAX_SIZE=5242880
# Import du référentiel (ticket 11, ADR-008) : on autorise le JSON canonique en plus
# des types par défaut (images/PDF). Le mime navigateur d'un .json = application/json.
UPLOAD_ALLOWED_EXTENSIONS=jpg,jpeg,png,webp,pdf,json
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf,application/json,text/plain

# Serveur
APP_HOST=127.0.0.1
APP_PORT=8000
# Dev : HTTPS local par défaut. Prod derrière Nginx : HTTP local par défaut.
# APP_SSL_ENABLED=true

# Certificats SSL (générés avec openssl, voir app.py)
SSL_CERTFILE=cert.pem
SSL_KEYFILE=key.pem

# Nonce CSP optionnel, désactivé par défaut.
# Activer pour permettre des scripts inline contrôlés
# avec {{ csp_nonce() }} dans les templates.
APP_CSP_NONCE_ENABLED=false

# Nom de la base de données du projet.=
# Serveur MariaDB : hôte et port, partagés par les comptes admin et applicatif.=
# Compte d'administration : provisioning (db:init) et DDL (db:apply, migrations).=
# Compte applicatif : runtime, DML uniquement (SELECT, INSERT, UPDATE, DELETE).=

# Base de données (forge-mvc-mariadb)
DB_NAME=
DB_HOST=127.0.0.1
DB_PORT=3306
# Compte d'administration de la base du projet (droits sur DB_NAME, pas le root serveur) : DDL, db:apply, migrations.=
DB_ADMIN_LOGIN=
DB_ADMIN_PWD=
DB_APP_LOGIN=
DB_APP_PWD=
