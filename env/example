# Application
APP_NAME=ReferenCiel-Manager
APP_ROUTES_MODULE=mvc.routes

# Base de données.
# Le cœur est agnostique BDD (ADR-054) et le squelette est livré SANS backend
# (ADR-060). Choisissez un backend, installez-le, puis renseignez ici ses
# variables de connexion selon sa documentation. Exemples :
#   - forge-mvc-sqlite  : un chemin de fichier, sans serveur ni comptes ;
#   - forge-mvc-mariadb : hôte, port, comptes d'administration (DB_ADMIN_*)
#     et applicatif (DB_APP_*), base, jeu de caractères (voir sa doc).
# forge new ne pré-remplit aucune de ces variables : elles appartiennent au
# backend, pas au squelette.

# Upload
# Le noyau ne garde que le plafond de corps multipart (ADR-032).
# UPLOAD_ROOT et UPLOAD_ALLOWED_* sont lues par l'opt-in forge-mvc-files.
UPLOAD_MAX_SIZE=5242880

# Serveur
APP_HOST=127.0.0.1
APP_PORT=8000
# Dev : HTTPS local par défaut. Prod derrière Nginx : HTTP local par défaut.
# APP_SSL_ENABLED=true

# Certificats SSL (générés avec openssl, voir app.py)
SSL_CERTFILE=cert.pem
SSL_KEYFILE=key.pem

# Nonce CSP optionnel, désactivé par défaut.
# Activer pour permettre des scripts inline contrôlés
# avec {{ csp_nonce() }} dans les templates.
APP_CSP_NONCE_ENABLED=false
