# Cohérence de mise en forme entre éditeurs (ADR-063).
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Les recettes de Makefile exigent des tabulations.
[Makefile]
indent_style = tab

# Fichiers de configuration : indentation à deux espaces.
[*.{yml,yaml,json,toml}]
indent_size = 2

# En Markdown, deux espaces en fin de ligne restent significatifs.
[*.md]
trim_trailing_whitespace = false
